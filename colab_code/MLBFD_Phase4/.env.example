# MLBFD Backend — Environment Variables
# Copy this file to .env and fill in your values.

# Flask secret key (change this in production)
MLBFD_SECRET_KEY=mlbfd-secret-key-2026

# SQLite database path (default: mlbfd.sqlite3 in the backend directory)
# MLBFD_DB_PATH=/path/to/mlbfd.sqlite3

# Fraud detection thresholds (0-100 risk scale)
MLBFD_THRESHOLD_CRITICAL=80
MLBFD_THRESHOLD_WARNING=50

# Layer weights for final risk aggregation (must sum to 1.0)
MLBFD_W_UBTS=0.20
MLBFD_W_WTS=0.20
MLBFD_W_WEBSITE=0.10
MLBFD_W_LSTM=0.25
MLBFD_W_ENSEMBLE=0.25

# API rate limit (requests per minute)
MLBFD_API_RATE_LIMIT=100
